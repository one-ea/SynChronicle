# Copy to .env.web and replace every placeholder before deployment.
POSTGRES_DB=synchronicle
POSTGRES_USER=synchronicle
POSTGRES_PASSWORD=replace-with-a-random-database-password
DATABASE_URL=postgres://synchronicle:replace-with-a-random-database-password@postgres:5432/synchronicle
PUBLIC_URL=https://synchronicle.example.com
SESSION_SECRET=replace-with-at-least-32-random-characters
PROJECT_CREDENTIAL_MASTER_KEYS=v1:replace-with-32-byte-base64-key
PROJECT_CREDENTIAL_MASTER_KEY_VERSION=v1
PROJECT_PROVIDER_ALLOWED_HOSTS={}
TRUST_PROXY=false
PORT=3000
WORKER_LEASE_MS=30000
WORKER_IDLE_MS=1000
QUOTA_STALE_AFTER_MS=60000
